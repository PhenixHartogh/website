---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialIcons from '../components/SocialIcons.astro';
---

<BaseLayout title="Nix Hartogh" description="Developer, builder, creator. Personal site of Nix Hartogh.">
  <section class="hero">
    <img
      src="https://cdn.on.an.unorthodox.site/headshot.png"
      alt="Nix Hartogh"
      class="headshot"
      width="120"
      height="120"
      loading="eager"
    />
    <h1>Nix Hartogh</h1>
    <p class="tagline">developer / builder / creator</p>
    <div class="social-row">
      <SocialIcons />
    </div>
  </section>

  <section class="about">
    <p>
      I build things for the web and beyond. Currently working on projects
      at the intersection of software, infrastructure, and creative technology.
    </p>
    <p>
      Based in Australia. Interested in systems programming, distributed systems,
      and making tools that developers actually enjoy using.
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }
  .headshot {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #1a1a1a;
    margin-bottom: 1.5rem;
  }
  h1 {
    font-size: 2.25rem;
    margin-bottom: 0.25rem;
  }
  .tagline {
    color: #888;
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
  }
  .social-row {
    display: flex;
    justify-content: center;
  }
  .about {
    max-width: 560px;
    margin: 0 auto;
  }
  .about p {
    color: #bbb;
    font-size: 0.95rem;
  }
</style>
