---
import SocialIcons from './SocialIcons.astro';
---

<footer>
  <div class="footer-inner">
    <SocialIcons />
    <p class="copyright">&copy; {new Date().getFullYear()} Nix Hartogh</p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid #1a1a1a;
    padding: 2rem 0;
    margin-top: 4rem;
  }
  .footer-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .copyright {
    color: #555;
    font-size: 0.8rem;
    font-family: "JetBrains Mono", "Fira Code", "SF Mono", "Cascadia Code", ui-monospace, monospace;
  }
</style>
